// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String       @id @default(uuid())
  name      String
  createdAt DateTime     @default(now())
  
  // Subscription / Limits
  maxEmployees Int      @default(10)
  status       String   @default("active") // active, inactive, suspended
  suspendedAt  DateTime?

  // Geofencing settings
  geofenceEnabled Boolean  @default(false)
  geofenceLat     Float?
  geofenceLng     Float?
  geofenceRadius  Int?     @default(100) // meters

  users     User[]
  employees Employee[]
  attendances Attendance[]
  attendanceCorrectionRequests AttendanceCorrectionRequest[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid())
  companyId    String?
  company      Company?   @relation(fields: [companyId], references: [id])
  name         String
  email        String    @unique
  passwordHash String
  role         String    // "admin" | "employee" | "superadmin"
  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [id])
  createdAt    DateTime  @default(now())
  reviewedAttendanceCorrections AttendanceCorrectionRequest[] @relation("attendanceCorrectionReviewer")

  @@map("users")
}

model Employee {
  id           String       @id @default(uuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  firstName    String
  lastName     String
  email        String       @unique
  documentId   String?      // DNI/Passport
  department   String       // Puesto de Trabajo
  birthDate    DateTime?
  businessName String?      // Razón Social
  workplace    String?      // Lugar de Trabajo
  workSchedule String?
  status       String       @default("active") // active, inactive
  joinDate     DateTime
  user         User?
  attendances  Attendance[]
  attendanceCorrectionRequests AttendanceCorrectionRequest[]
  createdAt    DateTime     @default(now())

  @@map("employees")
}

model AttendanceCorrectionRequest {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  attendanceId    String
  attendance      Attendance @relation(fields: [attendanceId], references: [id])
  markType        String
  requestedTime   String
  previousTimeAtRequest String
  previousTimeApplied   String?
  status          String   @default("pending")
  reason          String
  reviewComment   String?
  reviewedByUserId String?
  reviewedByUser   User?    @relation("attendanceCorrectionReviewer", fields: [reviewedByUserId], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, status, createdAt])
  @@index([employeeId, createdAt])
  @@index([attendanceId])
  @@map("attendance_correction_requests")
}

model Attendance {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id])
  date              DateTime
  
  checkIn           DateTime?
  latCheckIn        Float?
  lngCheckIn        Float?
  ipCheckIn         String?
  userAgentCheckIn  String?
  deviceCheckIn     String?
  osCheckIn         String?

  lunchStart        DateTime?
  latLunchStart     Float?
  lngLunchStart     Float?
  ipLunchStart         String?
  userAgentLunchStart  String?
  deviceLunchStart     String?
  osLunchStart         String?

  lunchEnd          DateTime?
  latLunchEnd       Float?
  lngLunchEnd       Float?
  ipLunchEnd         String?
  userAgentLunchEnd  String?
  deviceLunchEnd     String?
  osLunchEnd         String?

  checkOut          DateTime?
  latCheckOut       Float?
  lngCheckOut       Float?
  ipCheckOut         String?
  userAgentCheckOut  String?
  deviceCheckOut     String?
  osCheckOut         String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  correctionRequests AttendanceCorrectionRequest[]

  @@unique([employeeId, date])
  @@index([companyId, date])
  @@index([companyId, employeeId, date])
  @@map("attendances")
}
